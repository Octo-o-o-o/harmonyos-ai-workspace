/**
 * ErrorEventBuilder.ets — minimal HarmonyOS NEXT (ArkTS V1) skeleton showing
 * how to absorb the "every call site is `new Payload() + 4 lines + emit`"
 * boilerplate that ArkTS V1's no-object-literal rule forces on you.
 *
 * Pair with `05-best-practices/bridge-integration-pitfalls.md` §12.
 *
 * Drop-in pattern (NOT a runnable HAP — copy reportError / failAndUnregister
 * into your real plugin). Strictly per-service: do NOT extract a cross-service
 * generic builder (ESObject generics erase field-level type narrowing).
 */

// ---------------------------------------------------------------------------
// Mock types — replace with real generated payloads from your bridge contract.
// In OctoDesk: `apps/harmonyos/entry/src/main/ets/generated/OctoDeskMobileApi.ets`
// generated by openapi-generator from shared/contracts/native-shell.ts.
// ---------------------------------------------------------------------------

class BridgeUploadErrorEventPayload {
  correlationId: string = ''
  errorCode: string = ''
  errorMessage: string = ''
  retryable: boolean = false
}

class BridgeUploadStartRequestPayload {
  endpoint: string = ''
  method: string = 'POST'
  bodyJson?: string
}

// ---------------------------------------------------------------------------
// Service skeleton — illustrates the helper pattern with 4 different fail
// states that would otherwise each be ~5 lines of new / assign / emit.
// ---------------------------------------------------------------------------

export class UploadControllerExample {
  private active: Set<string> = new Set()

  /**
   * Centralised "emit error event" — every caller passes only the 4 fields
   * that actually vary. Saves the `new BridgeUploadErrorEventPayload()` +
   * 4× assign that would otherwise show up at every error site.
   *
   * Use this for failures BEFORE the upload was registered into `this.active`
   * (e.g. validation, dedup check). For post-registration failures use
   * `failAndUnregister` so the entry is cleaned up.
   */
  private reportError(
    corrId: string,
    code: string,
    message: string,
    retryable: boolean,
  ): void {
    const payload = new BridgeUploadErrorEventPayload()
    payload.correlationId = corrId
    payload.errorCode = code
    payload.errorMessage = message
    payload.retryable = retryable
    this.emitError(payload)
  }

  /**
   * Same as `reportError` but ALSO removes the entry from the active map.
   * Use AFTER the upload has been registered (so an `active.delete` is needed
   * for cleanup). Naming the helper after the side-effect — not generalising
   * — keeps the intent clear at call sites.
   */
  private failAndUnregister(
    corrId: string,
    code: string,
    message: string,
    retryable: boolean,
  ): void {
    this.reportError(corrId, code, message, retryable)
    this.active.delete(corrId)
  }

  /**
   * Call-site demo: 4 fail states, each ONE line.
   *
   * Compare to the anti-pattern in §12 where each `if` branch contained 5
   * lines of `new Payload + assign + assign + assign + emit`. With helpers
   * the branching reads as policy ("what's invalid → what code → cleanup?"),
   * not as boilerplate.
   */
  async startUpload(
    corrId: string,
    request: BridgeUploadStartRequestPayload,
  ): Promise<void> {
    // State 1 — pre-registration fail: validation
    if (!this.isAllowed(request.endpoint)) {
      this.reportError(corrId, 'BRIDGE.INVALID_PAYLOAD', 'endpoint not allowed', false)
      return
    }

    // State 2 — pre-registration fail: dedup
    if (this.active.has(corrId)) {
      this.reportError(corrId, 'BRIDGE.NATIVE_FAILURE', 'upload already running', false)
      return
    }

    // State 3 — pre-registration fail: method
    if (request.method !== 'POST' && request.method !== 'PUT') {
      this.reportError(corrId, 'BRIDGE.INVALID_PAYLOAD', 'method not allowed', false)
      return
    }

    this.active.add(corrId)

    try {
      await this.doUpload(corrId, request)
    } catch (err) {
      // State 4 — post-registration fail: network / IO; cleanup needed
      const message = err instanceof Error ? err.message : String(err)
      this.failAndUnregister(corrId, 'BRIDGE.NATIVE_FAILURE', message, true)
    }
  }

  // ---- stubs (replace with your real implementations) ----

  private isAllowed(_endpoint: string): boolean {
    return true
  }

  private async doUpload(
    _corrId: string,
    _request: BridgeUploadStartRequestPayload,
  ): Promise<void> {
    // ... real HTTP upload ...
  }

  private emitError(_payload: BridgeUploadErrorEventPayload): void {
    // ... real bridge.dispatch('upload.error', payload) ...
  }
}
